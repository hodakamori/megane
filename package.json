{
  "name": "megane-viewer",
  "version": "0.6.2",
  "type": "module",
  "description": "A fast, beautiful molecular viewer – anywidget-compatible",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hodakamori/megane.git"
  },
  "author": "hodakamori",
  "homepage": "https://github.com/hodakamori/megane",
  "keywords": [
    "molecular",
    "viewer",
    "pdb",
    "threejs",
    "chemistry",
    "anywidget",
    "jupyter"
  ],
  "main": "./dist/widget.js",
  "module": "./dist/widget.js",
  "exports": {
    ".": {
      "import": "./dist/widget.js"
    },
    "./lib": {
      "import": "./dist/lib.js"
    }
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build:wasm": "cd crates/megane-wasm && wasm-pack build --target web --release",
    "build": "npm run build:wasm && tsc && vite build && vite build --config vite.widget.config.ts && rm -rf dist && vite build --config vite.widget.config.ts --outDir dist && vite build --config vite.lib.config.ts && npm run build:lab",
    "build:app": "npm run build:wasm && tsc && vite build",
    "build:widget": "vite build --config vite.widget.config.ts",
    "build:lib": "npm run build:wasm && vite build --config vite.widget.config.ts --outDir dist && vite build --config vite.lib.config.ts",
    "build:lab": "cd jupyterlab-megane && npm install && npm run build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:webapp": "playwright test --project=webapp",
    "test:e2e:contract": "playwright test --project=contract",
    "test:e2e:widget-jupyterlab": "playwright test --project=widget-jupyterlab",
    "test:e2e:widget-examples": "playwright test --project=widget-examples",
    "test:e2e:widget-vscode": "playwright test --project=widget-vscode",
    "test:e2e:jupyterlab-doc": "playwright test --project=jupyterlab-doc",
    "test:e2e:vscode": "playwright test --project=vscode",
    "test:e2e:vscode:legacy": "node tests/e2e/vscode_full_screen.test.mjs",
    "test:e2e:vscode:legacy:update": "node tests/e2e/vscode_full_screen.test.mjs --update",
    "test:e2e:format-loading": "playwright test --project=format-loading",
    "test:e2e:playback": "playwright test --project=playback",
    "test:e2e:sidebar": "playwright test --project=sidebar",
    "test:e2e:widget-api": "playwright test --project=widget-api",
    "test:e2e:pipeline-editor": "playwright test --project=pipeline-editor",
    "test:e2e:pipeline-file": "playwright test --project=pipeline-file",
    "test:e2e:render-modal": "playwright test --project=render-modal",
    "test:e2e:modify-node": "playwright test --project=modify-node__webapp --project=modify-node__jupyterlab-doc --project=modify-node__vscode --project=modify-node__widget-jupyterlab --project=modify-node__widget-vscode",
    "test:e2e:modify-node:webapp": "playwright test --project=modify-node__webapp",
    "test:e2e:camera": "playwright test --project=camera__webapp --project=camera__jupyterlab-doc --project=camera__vscode --project=camera__widget-jupyterlab --project=camera__widget-vscode",
    "test:e2e:measurement": "playwright test --project=measurement__webapp --project=measurement__jupyterlab-doc --project=measurement__vscode --project=measurement__widget-jupyterlab --project=measurement__widget-vscode",
    "test:e2e:subsystems": "playwright test --project=subsystem-rendering__webapp --project=subsystem-rendering__jupyterlab-doc --project=subsystem-rendering__vscode --project=subsystem-rendering__widget-jupyterlab --project=subsystem-rendering__widget-vscode",
    "test:e2e:camera:webapp": "playwright test --project=camera__webapp",
    "test:e2e:measurement:webapp": "playwright test --project=measurement__webapp",
    "test:e2e:subsystems:webapp": "playwright test --project=subsystem-rendering__webapp",
    "test:e2e:trajectory-bonds": "playwright test --project=trajectory-bonds__webapp --project=trajectory-bonds__jupyterlab-doc --project=trajectory-bonds__vscode --project=trajectory-bonds__widget-jupyterlab --project=trajectory-bonds__widget-vscode",
    "test:e2e:trajectory-bonds:webapp": "playwright test --project=trajectory-bonds__webapp",
    "test:e2e:trajectory-bonds:jupyterlab-doc": "playwright test --project=trajectory-bonds__jupyterlab-doc",
    "test:e2e:trajectory-bonds:vscode": "playwright test --project=trajectory-bonds__vscode",
    "test:e2e:trajectory-bonds:widget-jupyterlab": "playwright test --project=trajectory-bonds__widget-jupyterlab",
    "test:e2e:trajectory-bonds:widget-vscode": "playwright test --project=trajectory-bonds__widget-vscode",
    "test:e2e:phase2": "playwright test --grep-invert='@phase0' --project=modify-node__webapp --project=camera__webapp --project=measurement__webapp --project=subsystem-rendering__webapp --project=trajectory-bonds__webapp",
    "test:all": "vitest run && playwright test",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "dependencies": {
    "@dagrejs/dagre": "^2.0.4",
    "@xyflow/react": "^12.0.0",
    "driver.js": "^1.4.0",
    "gif.js": "^0.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.183.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/dagre": "^0.7.54",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.183.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^25.0.0",
    "pixelmatch": "^6.0.0",
    "playwright": "1.56",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.0.0",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "^3.0.0"
  }
}
