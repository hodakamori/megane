{
  "name": "megane-viewer",
  "version": "0.6.0",
  "type": "module",
  "description": "A fast, beautiful molecular viewer – anywidget-compatible",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hodakamori/megane.git"
  },
  "author": "hodakamori",
  "homepage": "https://github.com/hodakamori/megane",
  "keywords": [
    "molecular",
    "viewer",
    "pdb",
    "threejs",
    "chemistry",
    "anywidget",
    "jupyter"
  ],
  "main": "./dist/widget.js",
  "module": "./dist/widget.js",
  "exports": {
    ".": {
      "import": "./dist/widget.js"
    },
    "./lib": {
      "import": "./dist/lib.js"
    }
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build:wasm": "cd crates/megane-wasm && wasm-pack build --target web --release",
    "build": "npm run build:wasm && tsc && vite build && vite build --config vite.widget.config.ts && vite build --config vite.widget.config.ts --outDir dist && vite build --config vite.lib.config.ts",
    "build:app": "npm run build:wasm && tsc && vite build",
    "build:widget": "vite build --config vite.widget.config.ts",
    "build:lib": "npm run build:wasm && vite build --config vite.widget.config.ts --outDir dist && vite build --config vite.lib.config.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node tests/e2e/snapshot.test.mjs",
    "test:all": "vitest run && node tests/e2e/snapshot.test.mjs",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "dependencies": {
    "@dagrejs/dagre": "^2.0.4",
    "@xyflow/react": "^12.0.0",
    "gif.js": "^0.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.183.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/dagre": "^0.7.54",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.183.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^25.0.0",
    "pixelmatch": "^6.0.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.0.0",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "^3.0.0"
  }
}
