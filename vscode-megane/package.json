{
  "name": "vscode-megane",
  "displayName": "megane - Molecular Viewer",
  "description": "View molecular structure files (PDB, GRO, XYZ, MOL, SDF, CIF, LAMMPS data, ASE traj, XTC, LAMMPS dump) with megane",
  "version": "0.6.2",
  "publisher": "hodakamori",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hodakamori/megane.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Visualization"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "megane.structureViewer",
        "displayName": "megane Molecular Viewer",
        "selector": [
          {
            "filenamePattern": "*.pdb"
          },
          {
            "filenamePattern": "*.gro"
          },
          {
            "filenamePattern": "*.xyz"
          },
          {
            "filenamePattern": "*.mol"
          },
          {
            "filenamePattern": "*.sdf"
          },
          {
            "filenamePattern": "*.cif"
          },
          {
            "filenamePattern": "*.data"
          },
          {
            "filenamePattern": "*.lammps"
          },
          {
            "filenamePattern": "*.traj"
          },
          {
            "filenamePattern": "*.xtc"
          },
          {
            "filenamePattern": "*.lammpstrj"
          },
          {
            "filenamePattern": "*.dump"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "megane.pipelineViewer",
        "displayName": "megane Pipeline Viewer",
        "selector": [
          {
            "filenamePattern": "*.megane.json"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "build:webview": "vite build --config vite.webview.config.ts",
    "build:extension": "tsc -p tsconfig.json",
    "build": "npm run build:webview && npm run build:extension",
    "watch": "tsc -p tsconfig.json --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@types/node": "^25.3.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.80.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vscode/vsce": "^3.0.0",
    "@xyflow/react": "^12.0.0",
    "gif.js": "^0.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.172.0",
    "typescript": "^5.7.0",
    "vite": "^6.4.2",
    "vite-plugin-wasm": "^3.5.0",
    "zustand": "^5.0.0"
  }
}
